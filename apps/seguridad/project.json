{
  "name": "seguridad",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/seguridad/src",
  "tags": ["scope:seguridad", "type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputPath": "dist/apps/seguridad",
      "options": {
        "browser": "apps/seguridad/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/seguridad/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/seguridad/public"
          },
          {
            "glob": "*.woff2",
            "input": "node_modules/geist/dist/fonts/geist-sans",
            "output": "fonts/geist"
          }
        ],
        "styles": ["apps/seguridad/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/styles/src"]
        }
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kB",
              "maximumError": "1MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kB",
              "maximumError": "16kB"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/seguridad/src/environments/environment.ts",
              "with": "apps/seguridad/src/environments/environment.prod.ts"
            }
          ]
        },
        "staging": {
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/seguridad/src/environments/environment.ts",
              "with": "apps/seguridad/src/environments/environment.staging.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "seguridad:build:production"
        },
        "development": {
          "buildTarget": "seguridad:build:development",
          "proxyConfig": "apps/seguridad/proxy.conf.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@angular/build:karma",
      "options": {
        "polyfills": ["zone.js", "zone.js/testing"],
        "tsConfig": "apps/seguridad/tsconfig.spec.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/seguridad/public"
          },
          {
            "glob": "*.woff2",
            "input": "node_modules/geist/dist/fonts/geist-sans",
            "output": "fonts/geist"
          }
        ],
        "styles": ["apps/seguridad/src/styles.scss"],
        "stylePreprocessorOptions": {
          "includePaths": ["libs/styles/src"]
        }
      }
    }
  }
}
